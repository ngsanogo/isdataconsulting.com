{
  "name": "isdataconsulting-stateless",
  "dockerComposeFile": [
    "docker-compose.devcontainer.yml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "remoteEnv": {
    "PATH": "/workspace/node_modules/.bin:/home/node/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
    "npm_config_cache": "/workspace/.npm",
    "XDG_CACHE_HOME": "/workspace/.cache"
  },
  "postCreateCommand": "chmod +x .devcontainer/post-create.sh && ./.devcontainer/post-create.sh",
  "postStartCommand": "chmod +x .devcontainer/post-start.sh && ./.devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "vitest.explorer",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/.cache/**": true,
          "**/__pycache__/**": true,
          "**/.venv/**": true,
          "**/venv/**": true,
          "**/target/**": true,
          "**/.uv/**": true
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
