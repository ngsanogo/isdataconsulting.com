#!/bin/sh
# Pre-commit hook - runs all checks in Docker containers

set -e

echo "Running pre-commit checks..."

# Lint and auto-fix
echo "\n→ Linting code..."
docker compose run --rm lint-fix

# Type checking
echo "\n→ Type checking..."
docker compose run --rm type-check

# Tests with coverage
echo "\n→ Running tests..."
docker compose run --rm test-coverage

echo "\n✓ Pre-commit checks passed\n"

exit 0
