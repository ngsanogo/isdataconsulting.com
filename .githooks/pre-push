#!/bin/sh
# Pre-push hook - runs full parity gate before push

set -e

echo "Running pre-push checks..."
echo "\n→ Running full gate..."

if ! command -v docker >/dev/null 2>&1 || ! docker compose version >/dev/null 2>&1; then
	echo "Docker + docker compose are required for repository checks"
	exit 1
fi

echo "\n→ Docker detected, executing make gate (CI parity + prod smoke)..."
make gate

echo "\n✓ Pre-push gate successful\n"

exit 0
