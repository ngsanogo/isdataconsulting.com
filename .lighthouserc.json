{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": ["http://localhost:4173/"]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.92
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2000
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "interactive": [
          "warn",
          {
            "maxNumericValue": 3500
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
