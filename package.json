{
  "name": "isdataconsulting",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:secrets": "node scripts/scan-secrets.mjs",
    "test:deps": "node scripts/test-dependencies.mjs",
    "deps:update": "npx npm-check-updates -u && npm install --legacy-peer-deps",
    "lint": "eslint . && npm run lint:ts",
    "lint:ts": "oxlint --tsconfig tsconfig.json --react-plugin --vitest-plugin src",
    "lint:fix": "eslint . --fix && npm run lint:fix:ts",
    "lint:fix:ts": "oxlint --fix --tsconfig tsconfig.json --react-plugin --vitest-plugin src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check": "npm run test:secrets && npm run test:deps && npm run lint && npm run type-check && npm test && npm run build",
    "clean": "rm -rf dist node_modules/.vite coverage"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "7.1.0-canary-ab18f33d-20260220",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.49.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
